		lineageTag: 350cc725-a93b-4135-b21e-560e749c94b7

	measure 'ROE A' = DIVIDE([NP A], [Eq A], 0)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 6a5f51e4-26d2-4da1-9425-78dbee49b190

	measure 'ROE B' = DIVIDE([NP B], [Eq B], 0)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: f55e9f34-4b3c-4d60-af42-057e9807e1ea

	measure 'NP Growth A' =
			
			VAR CurrentTK = SELECTEDVALUE(Dim_Calendar[TimeKey])
			VAR PrevTK = IF(RIGHT(CurrentTK, 1) = "1", CurrentTK - 7, CurrentTK - 1)
			VAR CurrentNP = [NP A]
			VAR PrevNP = CALCULATE([NP A], ALL(Dim_Calendar), Dim_Calendar[TimeKey] = PrevTK)
			RETURN DIVIDE(CurrentNP - PrevNP, PrevNP, 0)
		lineageTag: 3b88c647-8660-4b1b-82e6-06ab3bddc32a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'NP A' = CALCULATE([Value A], Dim_Items[ItemID] = "60")
		lineageTag: e67c8ba9-19f4-4805-8428-596c0b835a52

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'NP B' = CALCULATE([Value B], Dim_Items[ItemID] = "60")
