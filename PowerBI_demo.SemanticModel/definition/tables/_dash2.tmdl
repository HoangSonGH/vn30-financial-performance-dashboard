	measure Dynamic_Title_ROE =
			
			"ROE Trend: " & SELECTEDVALUE(Dim_Companies[Ticker], "A") & " vs " & SELECTEDVALUE(Dim_Companies_Peer[Ticker], "B")
		lineageTag: e7590f46-3a86-42f5-bf62-aa7aaac0da66

	measure Dynamic_Title_Profit =
			
			"Net Profit Growth: " & SELECTEDVALUE(Dim_Companies[Ticker], "A") & " vs " & SELECTEDVALUE(Dim_Companies_Peer[Ticker], "B")
		lineageTag: 6adecdfa-cd0a-45f0-bb21-ff59ea14ff3d

	measure 'NP Growth B' =
			
			VAR CurrentTK = SELECTEDVALUE(Dim_Calendar[TimeKey])
			VAR PrevTK = IF(RIGHT(CurrentTK, 1) = "1", CurrentTK - 7, CurrentTK - 1)
			VAR CurrentNP = [NP B]
			VAR PrevNP = CALCULATE([NP B], ALL(Dim_Calendar), Dim_Calendar[TimeKey] = PrevTK)
			RETURN DIVIDE(CurrentNP - PrevNP, PrevNP, 0)
		lineageTag: c0fe4e94-c6ba-41dd-93b8-653aa34f1465

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Dynamic_Title_Growth_EN = ```
			
			VAR TickerA = SELECTEDVALUE(Dim_Companies[Ticker], "Company A")
			VAR TickerB = SELECTEDVALUE(Dim_Companies_Peer[Ticker], "Company B")
			RETURN 
			"Net Profit Growth (QoQ): " & TickerA & " vs " & TickerB
			```
		lineageTag: ce25c2bf-2fd5-4c60-a1ab-cfa0ac413970

