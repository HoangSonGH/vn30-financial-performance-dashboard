table _dash2
	lineageTag: 4a97e734-b653-4116-9f2f-da7e046f9d3b

	measure Name_A = SELECTEDVALUE('dim_companies'[Name])
		lineageTag: 5f2a3491-2fd6-46b7-9104-85a8c88b88ae

	measure Logo_A = ```
			
			VAR OriginalLink = SELECTEDVALUE('dim_companies'[Logo_URL])
			/* Tách lấy File ID bằng cách thay phần đầu bằng rỗng */
			VAR FileID = SUBSTITUTE(OriginalLink, "https://drive.google.com/uc?export=view&id=", "")
			RETURN
			IF(
			    ISBLANK(FileID), 
			    BLANK(), 
			    "https://lh3.googleusercontent.com/d/" & FileID
			)
			```
		lineageTag: 3107d067-98bf-4483-9044-7bd486cdd4e2

	measure 'Value A' = [Total Value]
		lineageTag: af4e4e34-95e1-4058-b240-ec72bb3a9a4f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Value B' =
			
			VAR SelectedPeer = SELECTEDVALUE(Dim_Companies_Peer[Ticker])
			RETURN
			CALCULATE(
			    [Total Value],
			    REMOVEFILTERS(Dim_Companies),
			    TREATAS({SelectedPeer}, Dim_Companies[Ticker])
			)
		lineageTag: 95948717-dab5-47f9-bf6b-0c89687e8e92

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Hide_In_Slicer_A = ```
			
			VAR SelectedPeer = ALLSELECTED(Dim_Companies_Peer[Ticker])
			VAR CurrentCompany = SELECTEDVALUE(Dim_Companies[Ticker])
			RETURN 
			IF(CurrentCompany IN SelectedPeer, 0, 1)
			```
		formatString: 0
		lineageTag: 339827ca-488d-4578-a6cb-b0b3c58e6712

	measure Hide_In_Slicer_B = ```
			
			VAR SelectedCompany = ALLSELECTED(Dim_Companies[Ticker])
			VAR CurrentPeer = SELECTEDVALUE(Dim_Companies_Peer[Ticker])
			RETURN 
			IF(CurrentPeer IN SelectedCompany, 0, 1)
			```
		formatString: 0
		lineageTag: eda280d9-5b0c-4c47-99cb-9f276a1e38d1

	measure Name_B =
			
			SELECTEDVALUE(
			    Dim_Companies_Peer[Name], -- Thay bằng cột chứa tên công ty của bạn
